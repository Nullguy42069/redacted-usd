{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "build:extension": "rm -f public/redacted-extension.zip && cd ../../extension && zip -rq ../apps/web/public/redacted-extension.zip . -x '*.DS_Store' -x '.git/*' && echo 'Built: apps/web/public/redacted-extension.zip'",
    "prebuild": "npm run build:extension"
  },
  "dependencies": {
    "@emotion/cache": "^11.13.1",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/material-nextjs": "^9.0.1",
    "@redacted-usd/aggregator": "workspace:*",
    "@solana/spl-token": "^0.4.13",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-ledger": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-trezor": "^0.1.6",
    "@solana/web3.js": "^1.98.4",
    "@sqds/iframe-adapter": "^1.0.16",
    "@sqds/multisig": "^2.1.4",
    "@umbra-privacy/sdk": "5.0.0-rc.6",
    "@wallet-standard/app": "^1.1.1",
    "@wallet-standard/features": "^1.1.1",
    "bn.js": "^5.2.1",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.6",
    "typescript": "^5.7.2"
  }
}
