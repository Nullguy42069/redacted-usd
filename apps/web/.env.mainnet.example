# =============================================================================
# MAINNET CONFIGURATION — Redacted USD Privacy Aggregator
# =============================================================================
# Use this when you are ready for live mainnet testing with real SOL.
# WARNING: Mainnet transactions cost real money. Start small.
#
# Copy this file to .env.local (or set in your deployment platform like Vercel)
# and fill in the values below.

# --- RPC ---
# Use a good mainnet RPC (Helius, QuickNode, Alchemy, or Triton recommended for reliability)
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# --- Vault / Multisig ---
# The Squads multisig you want to use for testing on mainnet.
# Leave empty to require manual connection/selection in the UI.
NEXT_PUBLIC_DEFAULT_MULTISIG=

# --- Private Vote Programs (you must deploy these first) ---
# Deploy the private_vote program to mainnet and put the address here.
NEXT_PUBLIC_PRIVATE_VOTE_PROGRAM_ID=

# Deploy the private_vote_tee program to mainnet and put the address here.
NEXT_PUBLIC_PRIVATE_VOTE_TEE_PROGRAM_ID=

# --- MagicBlock TEE Router (for the TEE privacy backend) ---
# As of late 2026, check the current mainnet router endpoint from MagicBlock docs.
# The devnet one is https://devnet.magicblock.app
# Mainnet routers are usually under a different subdomain or require registration.
# Example (update with the real one when available):
# NEXT_PUBLIC_MAGIC_ROUTER_ENDPOINT=https://mainnet.magicblock.app
NEXT_PUBLIC_MAGIC_ROUTER_ENDPOINT=https://devnet.magicblock.app

# --- Arcium on mainnet ---
# 1. Deploy the private_vote + private_vote_tee programs + MXE using the Arcium CLI
# 2. Put the resulting program IDs and cluster offset here
# NEXT_PUBLIC_PRIVATE_VOTE_PROGRAM_ID=
# NEXT_PUBLIC_PRIVATE_VOTE_TEE_PROGRAM_ID=
# ARCIUM_MAINNET_OFFSET=0
# ARCIUM_MAINNET_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY   # or your preferred mainnet RPC

# --- Squads (only override for custom/private Squads deployments) ---
# NEXT_PUBLIC_SQUADS_PROGRAM_ID=SQDS4ep65T869zMMBKyuUq6aD6EgTu8psMjkvj52pCf
