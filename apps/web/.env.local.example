# Solana RPC. Use a Helius/QuickNode/Triton endpoint for production; the public
# mainnet endpoint is heavily rate-limited and not suitable for real use.
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: pin a Squads multisig PDA so the app loads it on first render.
# Format: base58 multisig PDA, NOT the vault address.
NEXT_PUBLIC_DEFAULT_MULTISIG=

# --- Privacy Program IDs (mainnet) ---
# These must be deployed on mainnet first. See docs or scripts for deployment.
# NEXT_PUBLIC_PRIVATE_VOTE_PROGRAM_ID=
# NEXT_PUBLIC_PRIVATE_VOTE_TEE_PROGRAM_ID=

# --- MagicBlock TEE Router (mainnet) ---
# Update this once you have a mainnet router endpoint from MagicBlock.
# NEXT_PUBLIC_MAGIC_ROUTER_ENDPOINT=https://mainnet.magicblock.app

# --- Squads (rarely needs override) ---
# NEXT_PUBLIC_SQUADS_PROGRAM_ID=SQDS4ep65T869zMMBKyuUq6aD6EgTu8psMjkvj52pCf

# --- WalletConnect (for dApp connections) ---
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
